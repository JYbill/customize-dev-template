{
  "wizard": {
    "lastRunAt": "2026-03-01T14:02:09.570Z",
    "lastRunVersion": "2026.2.26",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "agents": {
    "defaults": {
      // Agent 的默认工作目录，所有文件操作的根路径
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        // 对话历史压缩策略。
        // safeguard：分块摘要，更安全（防止长会话截断重要信息）
        "mode": "safeguard"
      },
      // 跨会话最多同时运行 4 个 Agent
      "maxConcurrent": 4,
      "subagents": {
        // 单次Agent对话期间最多同时委派8个子Agent完成任务
        "maxConcurrent": 8
      }
    }
  },
  "messages": {
    // 控制何时显示「已收到」确认表情
    // group-mentions：仅在群聊中被`@`提及才回应确认
    // all：总显示
    // none：不显示
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    // 自动在支持的平台（Discord/Telegram）注册原生斜杠Slash命令
    "native": "auto",
    // 自动在原生命令菜单中暴露技能命令
    "nativeSkills": "auto",
    // 允许通过聊天命令/restart触发Gateway 重启，也允许Agent使用 gateway 重启工具
    "restart": true,
    // 显示用户ID/名称时使用原始格式（不做任何渲染美化）
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "网关token密钥"
    },
    "controlUi": {
      // 允许非TLS认证
      "allowInsecureAuth": true,
      // ⚠️ 禁用设备身份验证，属于严重的安全降级措施。紧急使用后请立即恢复原设置。
      "dangerouslyDisableDeviceAuth": false,
      // Non-loopback 必须设置allowedOrigins设置允许的访问host
      "allowedOrigins": ["http://www.xiaoqinvar.cn:18789"]
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": ["camera.snap", "camera.clip", "screen.record", "calendar.add", "contacts.add", "reminders.add"]
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.2.26",
    "lastTouchedAt": "2026-03-01T14:02:09.580Z"
  }
}
